{
  "name": "local-ai-sdk-models",
  "version": "0.1.0",
  "description": "Download and cache Hugging Face GGUF models for local-ai-sdk.",
  "keywords": [
    "huggingface",
    "gguf",
    "local-llm",
    "download",
    "local-ai-sdk"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "expo-file-system": ">=16.0.0",
    "react-native-blob-util": ">=0.21.0"
  },
  "peerDependenciesMeta": {
    "expo-file-system": {
      "optional": true
    },
    "react-native-blob-util": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18"
  }
}
