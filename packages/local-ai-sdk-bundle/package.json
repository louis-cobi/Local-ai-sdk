{
  "name": "local-ai-sdk-bundle",
  "version": "0.1.0",
  "description": "Deprecated alias: re-exports local-ai-sdk only. Use local-ai-sdk directly.",
  "keywords": [
    "local-ai-sdk",
    "deprecated"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepack": "npm run build"
  },
  "dependencies": {
    "local-ai-sdk": "^0.1.0"
  },
  "peerDependencies": {
    "llama.rn": ">=0.5.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "llama.rn": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "local-ai-sdk": "*",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18"
  }
}
