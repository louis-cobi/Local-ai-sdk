{
  "name": "local-ai-sdk-llama",
  "version": "0.1.0",
  "description": "llama.rn LLMProvider for local-ai-sdk (multimodal mmproj, embeddings).",
  "keywords": [
    "llama.rn",
    "react-native",
    "llama",
    "local-ai-sdk",
    "gguf"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "llama.rn": ">=0.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "local-ai-sdk": "*",
    "llama.rn": "^0.5.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18"
  }
}
