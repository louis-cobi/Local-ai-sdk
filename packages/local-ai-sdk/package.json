{
  "name": "local-ai-sdk",
  "version": "0.1.0",
  "description": "Stateful local LLM runtime for React Native (llama.rn): session KV cache, tools, summarization, and optional RAG.",
  "keywords": [
    "llama",
    "llama.rn",
    "react-native",
    "local-llm",
    "ai",
    "zod",
    "gguf"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "react-native": "./dist/react.js",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./llama": {
      "types": "./dist/llama.d.ts",
      "react-native": "./dist/llama.js",
      "import": "./dist/llama.js",
      "require": "./dist/llama.cjs"
    },
    "./models/node": {
      "types": "./dist/models/node.d.ts",
      "node": {
        "import": "./dist/models/node.js",
        "require": "./dist/models/node.cjs"
      },
      "import": "./dist/models/node.js",
      "require": "./dist/models/node.cjs"
    },
    "./models/rn": {
      "types": "./dist/models/rn.d.ts",
      "react-native": "./dist/models/rn.js",
      "import": "./dist/models/rn.js",
      "require": "./dist/models/rn.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "@op-engineering/op-sqlite": ">=12.0.0",
    "expo-vector-search": ">=0.3.0",
    "expo": ">=53.0.0",
    "llama.rn": ">=0.10.0",
    "react": ">=19.0.0",
    "react-native": ">=0.79.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@op-engineering/op-sqlite": {
      "optional": true
    },
    "expo-vector-search": {
      "optional": true
    },
    "expo": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cobi/Local-ai-sdk.git",
    "directory": "packages/local-ai-sdk"
  },
  "homepage": "https://github.com/Cobi/Local-ai-sdk/tree/main/packages/local-ai-sdk",
  "bugs": {
    "url": "https://github.com/Cobi/Local-ai-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "zod": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "llama.rn": "^0.12.0-rc.9",
    "react": "^19.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
