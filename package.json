{
  "name": "local-ai-sdk-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/local-ai-sdk"
  ],
  "scripts": {
    "build": "npm run build -w local-ai-sdk",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "vitest run",
    "test:perf": "vitest run packages/local-ai-sdk/tests/perf-guardrails.test.ts",
    "test:ci": "npm run test && npm run test:perf",
    "test:e2e:rn:gemma4": "maestro test tests/e2e-rn/maestro/gemma4-mmproj.yaml",
    "test:e2e:rn:session": "maestro test tests/e2e-rn/maestro/session-multimodal-save-load.yaml",
    "test:e2e:rn:rag-restart": "maestro test tests/e2e-rn/maestro/rag-restart.yaml",
    "test:e2e:rn:download": "maestro test tests/e2e-rn/maestro/download-model.yaml",
    "test:e2e:rn:stream-stop": "maestro test tests/e2e-rn/maestro/chat-stream-stop.yaml",
    "test:e2e:rn:capabilities": "maestro test tests/e2e-rn/maestro/provider-capabilities.yaml",
    "test:e2e:rn:error-surface": "maestro test tests/e2e-rn/maestro/error-surface.yaml",
    "test:e2e:rn:full": "maestro test tests/e2e-rn/maestro/full-pass.yaml",
    "test:e2e:rn": "npm run test:e2e:rn:download && npm run test:e2e:rn:gemma4 && npm run test:e2e:rn:stream-stop && npm run test:e2e:rn:session && npm run test:e2e:rn:capabilities && npm run test:e2e:rn:error-surface && npm run test:e2e:rn:rag-restart",
    "e2e:rn:app:install": "npm install --prefix tests/e2e-rn/app",
    "e2e:rn:app:start": "npm run start --prefix tests/e2e-rn/app",
    "e2e:rn:app:android": "npm run android --prefix tests/e2e-rn/app",
    "e2e:rn:app:ios": "npm run ios --prefix tests/e2e-rn/app",
    "test:watch": "vitest",
    "test:packaging": "tsc -p tsconfig.packaging.json --noEmit",
    "test:smoke:exports": "node ./tests/packaging/smoke-exports.mjs && node ./tests/packaging/smoke-exports.cjs",
    "test:smoke:consumer-pack": "node ./tests/packaging/smoke-consumer-pack.mjs",
    "release:check": "npm run build && npm run test && npm run test:packaging && npm run test:smoke:exports && npm run test:smoke:consumer-pack && npm run test:e2e:rn:full"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "mermaid": "^11.14.0",
    "typescript": "^5.8.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
